// ─── ENUMS ───────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING       // Menunggu konfirmasi dokter
  CONFIRMED     // Dikonfirmasi, menunggu jadwal
  IN_PROGRESS   // Sedang berlangsung (video call aktif)
  COMPLETED     // Selesai
  CANCELLED     // Dibatalkan
  NO_SHOW       // Pasien tidak hadir
}

enum ConsultationType {
  VIDEO         // Video call
  AUDIO         // Audio only
  CHAT          // Async chat saja
}

enum SessionParticipantRole {
  DOCTOR
  NURSE
  PATIENT
  OBSERVER      // Supervisor / co-ass
}

// ─── MODELS ──────────────────────────────────────────────────

model TelemedicineAppointment {
  id                String              @id @default(cuid())
  
  // Relasi ke model User yang sudah ada
  patientId         String
  doctorId          String
  createdByStaffId  String
  
  // Detail jadwal
  scheduledAt       DateTime
  durationMinutes   Int                 @default(15)
  consultationType  ConsultationType   @default(VIDEO)
  status            AppointmentStatus  @default(PENDING)
  
  // BPJS / P-Care Integration
  bpjsNomorSEP      String?             // Surat Eligibilitas Peserta
  pCareNoKunjungan  String?             // Nomor kunjungan P-Care
  diagnosaICD10     String?             // Kode ICD-10 (dari modul ICD-X Converter)
  diagnosaInaCBGs   String?             // Kode INA-CBGs untuk klaim
  
  // Keluhan pasien sebelum konsultasi
  keluhanUtama      String?
  riwayatPenyakit   String?
  
  // Hasil konsultasi (diisi dokter)
  anamnesis         String?
  pemeriksaan       String?
  diagnosis         String?
  tatalaksana       String?
  resepDigital      Json?               // { obat, dosis, aturan }[]
  rujukan           Boolean            @default(false)
  rujukanTujuan     String?
  
  // LiveKit Room
  livekitRoomName   String?             @unique
  livekitRoomId     String?
  
  // SATUSEHAT
  satusehatEncounterId String?
  
  // Timestamps
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?          // Soft delete
  
  // Relations
  session           TelemedicineSession?
  attachments       TelemedicineAttachment[]
  auditLogs         TelemedicineAuditLog[]
  
  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@map("telemedicine_appointments")
}

model TelemedicineSession {
  id              String    @id @default(cuid())
  appointmentId   String    @unique
  
  // LiveKit room credentials
  roomName        String    @unique
  roomSid         String?   // LiveKit room SID
  
  // Recording (jika diperlukan untuk audit medis)
  recordingEnabled Boolean  @default(false)
  recordingUrl    String?   // Encrypted, S3/MinIO path
  recordingConsent Boolean  @default(false)
  
  // Durasi aktual
  actualStartAt   DateTime?
  actualEndAt     DateTime?
  actualDurationSeconds Int?
  
  // Network quality log
  avgNetworkQuality Json?   // { doctor: number, patient: number }
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  appointment     TelemedicineAppointment @relation(fields: [appointmentId], references: [id])
  participants    TelemedicineParticipant[]
  
  @@map("telemedicine_sessions")
}

model TelemedicineParticipant {
  id          String                    @id @default(cuid())
  sessionId   String
  userId      String
  role        SessionParticipantRole
  
  // LiveKit participant identity
  livekitIdentity String
  
  joinedAt    DateTime?
  leftAt      DateTime?
  
  session     TelemedicineSession @relation(fields: [sessionId], references: [id])
  
  @@index([sessionId])
  @@map("telemedicine_participants")
}

model TelemedicineAttachment {
  id              String    @id @default(cuid())
  appointmentId   String
  uploadedByUserId String
  
  // File info
  fileName        String
  fileType        String    // image/jpeg, application/pdf, etc.
  fileSizeBytes   Int
  
  // Encrypted storage path (MinIO/S3)
  storagePath     String
  encryptionKeyId String    // Reference ke KMS key
  
  // Kategori
  category        String    // foto_gejala, hasil_lab, resep, dll
  
  createdAt       DateTime  @default(now())
  deletedAt       DateTime? // Soft delete
  
  appointment     TelemedicineAppointment @relation(fields: [appointmentId], references: [id])
  
  @@index([appointmentId])
  @@map("telemedicine_attachments")
}

// Audit log khusus telemedicine (HIPAA-inspired)
model TelemedicineAuditLog {
  id              String    @id @default(cuid())
  appointmentId   String
  userId          String
  action          String    // JOIN_ROOM, LEAVE_ROOM, START_RECORDING, etc.
  metadata        Json?     // IP, user agent, dll
  createdAt       DateTime  @default(now())
  
  appointment     TelemedicineAppointment @relation(fields: [appointmentId], references: [id])
  
  @@index([appointmentId])
  @@index([userId])
  @@map("telemedicine_audit_logs")
}
